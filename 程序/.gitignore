# 含 API Key，切勿提交
config.json
error.log
__pycache__/
*.pyc
samples/*_zh.pdf
samples/*_bi.pdf
# 生成物（由 samples/make_*.py 随时重建，不入库）
samples/sample_scanned.pdf
samples/sample_paper_translation.pdf
samples/sample_table.pdf
samples/sample_doc.docx
samples/sample_slides.pptx
test-results.xml
# 持久化翻译缓存与自测输出
cache/
selftest_out/
# 版面分析模型（72MB，按 docs/前端设计.md 或 handoff 指引单独下载）
models/
# 打包产物（体积大且可随时重建；发布时上传到 GitHub Releases 而非仓库）
build/
release/*
# 例外：版本台账必须入库——二进制不留，但"发过哪些版本"要永久可查
# （用 release/* 而非 release/，否则目录被整体排除，下面的取反不生效）
!release/RELEASES.md
*.spec
